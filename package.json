{
  "name": "master-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "build:vercel": "vite build",
    "start": "node dist/server.cjs",
    "preview": "vite preview --port=3000 --host=0.0.0.0",
    "clean": "rm -rf dist server.js server.cjs",
    "lint": "tsc --noEmit",
    "db:setup": "tsx scripts/setup-database.ts",
    "db:check": "tsx scripts/check-database.ts",
    "db:seed-teja": "tsx scripts/seed-teja-user.ts",
    "db:seed-expanded": "tsx scripts/seed-expanded-data.ts",
    "db:verify": "tsx scripts/verify-system.ts",
    "db:bootstrap": "tsx scripts/bootstrap-realtime.ts"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@radix-ui/react-slot": "^1.2.5",
    "@supabase/supabase-js": "^2.108.2",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "postgres": "^3.4.9",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.18.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/express": "^5.0.6",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
